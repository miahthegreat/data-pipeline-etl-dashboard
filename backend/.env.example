DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pipeline_dashboard
# Optional: default webhook for alert rules (Slack incoming webhook URL)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional: run alert check every N minutes (0 = disabled). Default 15.
# ALERT_CHECK_INTERVAL_MINUTES=15
# Optional: CORS allowed origins (comma-separated). Default allows localhost:5173.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
