# Copy to profiles.yml and set your connection.
# dbt looks for profiles.yml in ~/.dbt/ or DBT_PROFILES_DIR.
pipeline_dashboard:
  target: dev
  outputs:
    dev:
      type: postgres
      host: localhost
      port: 5433
      user: postgres
      password: postgres
      dbname: pipeline_dashboard
      schema: public
      threads: 4
